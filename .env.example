# OpenRouteService API key — sign up free at https://openrouteservice.org/
# Required for /api/route walking-directions endpoint.
# Do NOT prefix with VITE_ — this must stay server-side only.
ORS_API_KEY=your_ors_key_here

# Dev-only: mock GPS coordinates for the simulator (no real GPS available).
# Only active when running `npm run dev` — tree-shaken out of production builds.
# Remove or leave blank to use real device GPS.
VITE_MOCK_LAT=
VITE_MOCK_LNG=
